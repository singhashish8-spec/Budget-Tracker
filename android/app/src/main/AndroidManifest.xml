<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Backup is ON, but strictly limited to ONE file: the app's own JSON
      snapshot (files/budget-tracker-autobackup.json). See backup_rules.xml and
      data_extraction_rules.xml, which use include-lists so nothing else can
      travel by accident.

      The raw SQLite database is deliberately NOT backed up. It's device-local
      plumbing; the JSON snapshot carries the same information in a portable,
      mergeable form that restores cleanly onto any install or new phone, which
      is why it — and only it — is allowed out. (Historically the database was
      SQLCipher-encrypted with a hardware-bound Keystore key that couldn't
      travel with the file, so a restored copy was undecryptable and bricked
      the app; the database is now plaintext, but excluding it is still correct.)

      This is what makes the data survive a reinstall or a new phone, instead
      of the user losing everything and being sent back through onboarding.
    -->
    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read bank/UPI transaction SMS for auto-tracking (requested at runtime) -->
    <uses-permission android:name="android.permission.READ_SMS" />
</manifest>
