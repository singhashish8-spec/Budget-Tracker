<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+. Same intent as backup_rules.xml: keep the encrypted database out
     of cloud backup and device-to-device transfer, since its Keystore key
     can't travel with it. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
