<?xml version="1.0" encoding="utf-8"?>
<!-- API < 31. Never back up the encrypted database or prefs: the SQLCipher key
     lives in the Keystore and can't be restored, so a restored DB would be
     undecryptable. The app has its own JSON backup instead. -->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
